---
import "../styles/landing.css";
import logoSrc from "../../../docs/assets/logo.svg?url";
import arrowIconSrc from "../../../docs/assets/icons/arrow.svg?url";
import githubIconSrc from "../../../docs/assets/icons/github.svg?url";

import codexLogoSrc from "../../../docs/assets/agents/codex-color.svg?url";
import codexTransparentLogoSrc from "../../../docs/assets/agents/codex-transparent.svg?url";
import claudecodeLogoSrc from "../../../docs/assets/agents/claudecode-color.svg?url";
import opencodeLogoSrc from "../../../docs/assets/agents/opencode-light.svg?url";
import opencodeDarkLogoSrc from "../../../docs/assets/agents/opencode-dark.svg?url";
import kilocodeLogoSrc from "../../../docs/assets/agents/kilocode.svg?url";
import kiroLogoSrc from "../../../docs/assets/agents/kiro-color.svg?url";
import clineLogoSrc from "../../../docs/assets/agents/cline.svg?url";
import hermesLogoSrc from "../../../docs/assets/agents/hermesagent.svg?url";
import antigravityLogoSrc from "../../../docs/assets/agents/antigravity-color.svg?url";
import mcpLogoSrc from "../../../docs/assets/agents/mcp.svg?url";

const pageTitle =
  "Ennodia - multi-agent review with Compare and traceable receipts";
const pageDescription =
  "Ennodia lets your primary agent ask installed local AI tools for second opinions, track every run, and surface disagreements with model-led Compare.";
const siteUrl = Astro.site ?? new URL("https://ennodia.cherninlab.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL("/og.png", siteUrl).toString();
const socialImageAlt = "Ennodia wordmark.";

const adapters = [
  { name: "Codex", logoSrc: codexLogoSrc },
  { name: "Claude Code", logoSrc: claudecodeLogoSrc },
  { name: "OpenCode", logoSrc: opencodeLogoSrc },
  { name: "Kilo Code", logoSrc: kilocodeLogoSrc },
  { name: "Kiro", logoSrc: kiroLogoSrc },
  { name: "Cline", logoSrc: clineLogoSrc },
  { name: "Hermes Agent", logoSrc: hermesLogoSrc },
  { name: "Antigravity", logoSrc: antigravityLogoSrc },
];

const installCommand = "npx -y ennodia";
const agentInstallPrompt = "try-ennodia.cherninlab.com";
const heroAgentInstallPrompt = "try-ennodia.cherninlab.com";
const mcpConfigSnippet = `{
  "mcpServers": {
    "ennodia": {
      "command": "npx",
      "args": ["-y", "ennodia"]
    }
  }
}`;
const examplePrompt = `Use Ennodia to ask the best available local agents:
"Review this change before I ship it. Find the highest-risk issue, docs drift, and install confusion. Compare disagreements with a model and give me the next action."`;
const examples = [
  {
    title: "Stubborn bug",
    text: "Run several agents when one answer is not enough, then compare the likely root causes before editing.",
  },
  {
    title: "Planning tradeoff",
    text: "Ask different models for migration plans so their biases show up before the project commits to one path.",
  },
  {
    title: "Skill comparison",
    text: "Run with and without a skill such as source-grounded-audit, then compare what the skill changed.",
  },
  {
    title: "Large plan review",
    text: "Split a broad proposal into focused audit slices, send them to different local agents, then synthesize the useful results.",
  },
  {
    title: "Benchmark receipts",
    text: "Check deterministic bug-recall fixtures before trusting the pitch, then rerun them from the checkout.",
  },
];
const interfaces = [
  {
    title: "Ennodia MCP",
    logoSrc: mcpLogoSrc,
    status: "Available",
    text: "The shipped interface agents use today: MCP tools for harness discovery, runs, budget checks, tasks, and Compare.",
  },
  {
    title: "Ennodia Core",
    status: "Available",
    text: "The shared orchestration behavior behind MCP and the IO package: routing, task lifecycle, failure visibility, and model-led synthesis.",
  },
];
const advantages = [
  "Uses local agent CLIs, installs, subscriptions, and model choices you already have as a review panel",
  "Discovers supported harnesses automatically and keeps adapters thin",
  "Provides a preflight input-token estimate plus hard local caps for max child tasks and estimated input",
  "Tracks child task IDs, ETA, output, failures, Compare state, and durable terminal run history",
  "Lets a model judge and synthesize parallel answers so the user is not the comparison engine",
  "Keeps model and skill preference memory on the roadmap instead of pretending it exists",
];
const faqItems = [
  {
    question: "What is Ennodia?",
    answer:
      "Ennodia is a local MCP server for multi-agent review: your primary agent can ask other installed agent CLIs for second opinions, then compare the answers.",
  },
  {
    question: "Why would one AI agent ask other agents for help?",
    answer:
      "Different agents miss different things. Ennodia is useful when extra model work is worth spending because quality, risk, or planning uncertainty matters.",
  },
  {
    question: "How long does a run take?",
    answer:
      "Usually minutes, not seconds. Ennodia starts real local agent CLIs, and Compare adds a judge pass plus a synthesizer pass after child agents finish.",
  },
  {
    question: "Do I need to know MCP?",
    answer:
      "No. You can paste the install line into Codex, Claude Code, Antigravity, or another agent and ask it to install Ennodia for you.",
  },
  {
    question: "Does Ennodia replace my main AI agent?",
    answer:
      "No. Your primary agent stays in charge. Ennodia gives it a way to route a question to other local agents and bring their answers back into the same workflow.",
  },
  {
    question: "Which agents can Ennodia ask?",
    answer:
      "Ennodia works through local harness adapters for agent CLIs such as Codex CLI, Claude Code, OpenCode, Kilo Code, Kiro CLI, Cline CLI, Hermes Agent, and Antigravity.",
  },
  {
    question: "Does Ennodia expose an OpenAI-compatible API?",
    answer:
      "The separate Ennodia IO package exposes experimental local provider options and a non-streaming chat-completions subset.",
  },
  {
    question: "Does Ennodia send my code to Ennodia servers?",
    answer:
      "No. Ennodia runs locally and does not use an Ennodia-hosted service. The child agent CLIs you choose may still call their own model providers according to their own settings.",
  },
  {
    question: "Why not manually copy prompts between tools?",
    answer:
      "Manual copy-paste loses traceability and makes you the judge. Ennodia keeps selected agents, task IDs, failures, timing, outputs, model-led Compare, and the final answer in one run.",
  },
  {
    question: "Can Ennodia limit spend?",
    answer:
      "Ennodia can estimate preflight input tokens and enforce local limits such as maxChildTasks and maxEstimatedInputTokens on that estimate. It cannot know provider billing or harness-internal context in advance.",
  },
  {
    question: "Is there a benchmark?",
    answer:
      "Yes. The deterministic bug-recall benchmark is published in the docs with a dated snapshot and can be rerun from a checkout with bun run bench:bug-recall.",
  },
  {
    question: "Does Ennodia support files and screenshots?",
    answer:
      "File and screenshot workflows depend on what each local harness can access. Include file paths and short descriptions today; better attachment staging is an important next step.",
  },
  {
    question: "Is Ennodia only for code review?",
    answer:
      "No. Code review is a good fit, but Ennodia also works for docs audits, release checks, migrations, research checks, and design critique.",
  },
];
const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
const softwareStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Ennodia",
  description: pageDescription,
  url: siteUrl.toString(),
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  license: "https://opensource.org/license/mit/",
  downloadUrl: "https://www.npmjs.com/package/ennodia",
  sameAs: ["https://github.com/cherninlab/ennodia"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#fbfbfa" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ennodia" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(faqStructuredData)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(softwareStructuredData)}
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <main id="main-content">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-inner">
          <h1 id="hero-title">
            <span class="sr-only">Ennodia. </span>
            <img class="hero-logo" src={logoSrc} alt="" aria-hidden="true" />
            <span class="hero-title-text">AI makes mistakes</span>
          </h1>
          <p class="hero-subtitle">
            But what&nbsp;one&nbsp;misses, another&nbsp;catches!
          </p>
          <div
            class="hero-terminal"
            role="img"
            aria-label="Three AI tools review the same work, compare their answers, and return one checked answer."
          >
            <div class="terminal-command">
              <span class="terminal-muted">›</span>
              <span class="terminal-typed">review this before I ship it</span>
              <span class="terminal-cursor" aria-hidden="true"></span>
            </div>
            <div class="terminal-line terminal-delay-1">
              <span class="terminal-muted"
                >asking three AIs for their opinion...</span
              >
            </div>
            <div class="terminal-rows">
              <div class="terminal-line terminal-row terminal-delay-2">
                <img src={codexTransparentLogoSrc} alt="" aria-hidden="true" />
                <span>Codex</span>
                <span class="terminal-bar" aria-hidden="true">
                  <span style="--bar-width: 54%; --bar-color: #2a78d6"></span>
                </span>
                <span class="terminal-status">✓ 2.1 min</span>
              </div>
              <div class="terminal-line terminal-row terminal-delay-3">
                <img src={claudecodeLogoSrc} alt="" aria-hidden="true" />
                <span>Claude Code</span>
                <span class="terminal-bar" aria-hidden="true">
                  <span style="--bar-width: 85%; --bar-color: #1baf7a"></span>
                </span>
                <span class="terminal-status">✓ 3.4 min</span>
              </div>
              <div class="terminal-line terminal-row terminal-delay-4">
                <img src={opencodeDarkLogoSrc} alt="" aria-hidden="true" />
                <span>OpenCode</span>
                <span class="terminal-bar" aria-hidden="true">
                  <span style="--bar-width: 31%; --bar-color: #eda100"></span>
                </span>
                <span class="terminal-status">✓ 1.2 min</span>
              </div>
            </div>
            <div class="terminal-line terminal-delay-5">
              <span class="terminal-muted">comparing their answers...</span>
            </div>
            <div class="terminal-line terminal-good terminal-delay-6">
              ✓ all three agree on 2 issues
            </div>
            <div class="terminal-line terminal-warn terminal-delay-7">
              ! only Claude Code caught the 3rd - the risky one
            </div>
            <div class="terminal-line terminal-final terminal-delay-8">
              → one answer, checked three ways
            </div>
          </div>
          <div class="hero-prompt">
            <p class="snippet-label">Paste this into your agent</p>
            <div class="code-copy">
              <pre><code>try-ennodia.cherninlab.com</code></pre>
              <button
                class="copy-button"
                type="button"
                data-copy-code={heroAgentInstallPrompt}
                aria-label="Copy agent install prompt"></button>
              <span class="copy-status" data-copy-status aria-live="polite"
              ></span>
            </div>
          </div>
          <div class="hero-links" aria-label="More links">
            <a href="/docs/getting-started/">Read docs</a>
            <span aria-hidden="true">·</span>
            <a class="github-link" href="https://github.com/cherninlab/ennodia">
              <img src={githubIconSrc} alt="" aria-hidden="true" />
              GitHub
            </a>
          </div>
        </div>
      </section>

      <section
        class="section adapters-section"
        aria-labelledby="adapters-title"
      >
        <div class="section-label">Agents</div>
        <div class="section-body">
          <h2 id="adapters-title">Compatible local agents</h2>
          <p>
            Ennodia works through supported local harnesses. It does not provide
            a hosted model account or replace the subscriptions those tools use.
          </p>
          <ul class="adapter-list">
            {
              adapters.map((adapter) => (
                <li>
                  <img
                    src={adapter.logoSrc}
                    class="adapter-logo"
                    alt=""
                    aria-hidden="true"
                  />
                  <strong>{adapter.name}</strong>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="section faq-section" aria-labelledby="faq-title">
        <div class="section-label">FAQ</div>
        <div class="section-body">
          <h2 id="faq-title">Common questions</h2>
          <div class="faq-list">
            {
              faqItems.map((item) => (
                <details>
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section code-section" aria-labelledby="install-title">
        <div class="section-label">Getting Started</div>
        <div class="section-body">
          <h2 id="install-title">Install Ennodia</h2>
          <div class="install-layout">
            <div>
              <p>
                Send the install link to your primary agent, or add Ennodia to
                an MCP client directly.
              </p>
            </div>
            <div class="install-snippets">
              <div>
                <p class="snippet-label">Agent prompt</p>
                <div class="code-copy">
                  <pre><code>{agentInstallPrompt}</code></pre>
                  <button
                    class="copy-button"
                    type="button"
                    data-copy-code={agentInstallPrompt}
                    aria-label="Copy agent install prompt"></button>
                  <span class="copy-status" data-copy-status aria-live="polite"
                  ></span>
                </div>
              </div>
              <div>
                <p class="snippet-label">Command</p>
                <div class="code-copy">
                  <pre><code>{installCommand}</code></pre>
                  <button
                    class="copy-button"
                    type="button"
                    data-copy-code={installCommand}
                    aria-label="Copy install command"></button>
                  <span class="copy-status" data-copy-status aria-live="polite"
                  ></span>
                </div>
              </div>
              <div>
                <p class="snippet-label">MCP config</p>
                <div class="code-copy">
                  <pre><code>{mcpConfigSnippet}</code></pre>
                  <button
                    class="copy-button"
                    type="button"
                    data-copy-code={mcpConfigSnippet}
                    aria-label="Copy MCP config"></button>
                  <span class="copy-status" data-copy-status aria-live="polite"
                  ></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section intro-section" aria-labelledby="intro-title">
        <div class="section-label">Use cases</div>
        <div class="section-body">
          <h2 id="intro-title">What Ennodia helps with</h2>
          <ul class="example-list">
            {
              examples.map((example) => (
                <li>
                  <h3>{example.title}</h3>
                  <p>{example.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="section example-section" aria-labelledby="example-title">
        <div class="section-label">Example prompt</div>
        <div class="section-body">
          <h2 id="example-title">Try a model-led review</h2>
          <p>
            This asks Ennodia to run other agents, compare disagreements, and
            return one next action.
          </p>
          <div class="code-copy">
            <pre><code>{examplePrompt}</code></pre>
            <button
              class="copy-button"
              type="button"
              data-copy-code={examplePrompt}
              aria-label="Copy example prompt"></button>
            <span class="copy-status" data-copy-status aria-live="polite"
            ></span>
          </div>
        </div>
      </section>

      <section class="section process-section" aria-labelledby="loop-title">
        <div class="section-label">Process</div>
        <div class="section-body">
          <h2 id="loop-title">How Ennodia runs</h2>
          <ol class="process-diagram" aria-label="Ennodia request flow">
            <li>
              <div class="process-number">1</div>
              <div class="process-copy">
                <h3>Ask</h3>
                <p>Your primary agent sends one request.</p>
              </div>
              <div class="process-visual">
                <span class="process-node">Agent</span>
                <span class="process-line" aria-hidden="true"></span>
                <span class="process-node process-node-dark">Ennodia</span>
              </div>
            </li>
            <li>
              <div class="process-number">2</div>
              <div class="process-copy">
                <h3>Route</h3>
                <p>Available local harnesses are selected.</p>
              </div>
              <div class="process-visual process-visual-cluster">
                <span class="process-node process-node-dark">Ennodia</span>
                <span class="process-line" aria-hidden="true"></span>
                <span class="process-cluster" aria-label="Selected agents">
                  <span class="process-node process-node-small">Codex</span>
                  <span class="process-node process-node-small">Claude</span>
                  <span class="process-node process-node-small">Antigrav</span>
                </span>
              </div>
            </li>
            <li>
              <div class="process-number">3</div>
              <div class="process-copy">
                <h3>Review</h3>
                <p>Each agent answers independently.</p>
              </div>
              <div class="process-visual process-visual-cluster">
                <span class="process-cluster" aria-label="Agent answers">
                  <span class="process-node process-node-small">A</span>
                  <span class="process-node process-node-small">B</span>
                  <span class="process-node process-node-small">C</span>
                </span>
                <span class="process-line" aria-hidden="true"></span>
                <span class="process-node process-node-dotted">Compare</span>
              </div>
            </li>
            <li>
              <div class="process-number">4</div>
              <div class="process-copy">
                <h3>Return</h3>
                <p>A model compares; you get the answer and trace.</p>
              </div>
              <div class="process-visual">
                <span class="process-node process-node-dotted">Judge</span>
                <span class="process-line" aria-hidden="true"></span>
                <span class="process-node process-node-dark">Answer</span>
                <span class="process-node process-node-small">Trace</span>
              </div>
            </li>
          </ol>
        </div>
      </section>

      <section
        class="section interfaces-section"
        aria-labelledby="interfaces-title"
      >
        <div class="section-label">Interfaces</div>
        <div class="section-body">
          <h2 id="interfaces-title">Core & MCP</h2>
          <ul class="example-list">
            {
              interfaces.map((item) => (
                <li>
                  <h3>
                    {item.logoSrc && (
                      <img
                        src={item.logoSrc}
                        class="interface-logo"
                        alt=""
                        aria-hidden="true"
                      />
                    )}
                    {item.title}
                  </h3>
                  <p class="inline-note">{item.status}</p>
                  <p>{item.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="section compare-section" aria-labelledby="compare-title">
        <div class="section-label">Budget</div>
        <div class="section-body">
          <h2 id="compare-title">Spend extra model work on purpose</h2>
          <ul class="use-list">
            {advantages.map((advantage) => <li>{advantage}</li>)}
          </ul>
        </div>
      </section>

      <section
        class="section compare-section"
        aria-labelledby="model-compare-title"
      >
        <div class="section-label">Compare</div>
        <div class="section-body">
          <h2 id="model-compare-title">The model does the comparison</h2>
          <ol class="compare-flow" aria-label="Ennodia compare flow">
            <li>
              <div class="concept-mark" aria-hidden="true">1</div>
              <div>
                <h3>Judge</h3>
                <p>
                  Names agreements, disagreements, missing context, unique
                  value, and risk.
                </p>
              </div>
            </li>
            <li>
              <div class="concept-mark" aria-hidden="true">2</div>
              <div>
                <h3>Synthesizer</h3>
                <p>
                  Turns the original answers and judge notes into one answer the
                  caller can use.
                </p>
              </div>
            </li>
            <li>
              <div class="concept-mark" aria-hidden="true">3</div>
              <div>
                <h3>Trace</h3>
                <p>
                  Keeps task IDs, failures, timing, partial output, and final
                  status visible.
                </p>
              </div>
            </li>
          </ol>
        </div>
      </section>

      <section
        class="section compare-section"
        aria-labelledby="benchmark-title"
      >
        <div class="section-label">Receipts</div>
        <div class="section-body">
          <h2 id="benchmark-title">Bug-recall benchmark</h2>
          <p>
            The current deterministic snapshot covers 4 TypeScript review
            fixtures. Ennodia parallel Compare scored 100% recall and 100%
            precision in fixture mode, with limitations documented beside the
            table.
          </p>
          <p>
            <a href="/docs/reference/benchmarks/">Read the benchmark snapshot</a
            >
          </p>
        </div>
      </section>

      <section class="section credits-section" aria-labelledby="credits-title">
        <div class="section-label">Credits</div>
        <div class="section-body">
          <article class="credits-card">
            <h2 id="credits-title">
              Inspired by <a href="https://github.com/karpathy/llm-council"
                >karpathy/llm-council</a
              >
            </h2>
            <p>
              LLM Council demonstrates the pattern: ask several models
              independently, compare, synthesize. Ennodia brings that pattern
              into local agent workflows, MCP, task tracing, failure visibility,
              and reusable harness adapters.
            </p>
          </article>
        </div>
      </section>

      <section class="section cta-section" aria-labelledby="cta-title">
        <div class="section-label">Get started</div>
        <div class="section-body">
          <h2 id="cta-title">Ask for second opinions</h2>
          <p>
            Paste the install line into your primary agent, then ask it to bring
            in reviewers when a task deserves more than one model.
          </p>
          <div class="hero-actions cta-actions" aria-label="Final actions">
            <a class="button button-primary" href="/install">
              Install
              <img src={arrowIconSrc} alt="" aria-hidden="true" />
            </a>
            <a
              class="button button-plain"
              href="https://github.com/cherninlab/ennodia"
            >
              <img src={githubIconSrc} alt="" aria-hidden="true" />
              GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <img src={logoSrc} alt="Ennodia" />
        <p>Open source. Local first. MIT licensed.</p>
      </div>
    </footer>
    <script>
      const copyButtons = document.querySelectorAll("[data-copy-code]");

      async function copyText(text) {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.append(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      }

      for (const button of copyButtons) {
        button.addEventListener("click", async () => {
          const code = button.getAttribute("data-copy-code") ?? "";
          const status =
            button.parentElement?.querySelector("[data-copy-status]");

          try {
            await copyText(code);
            button.setAttribute("data-copied", "true");
            if (status) {
              status.textContent = "Copied";
            }
          } catch {
            if (status) {
              status.textContent = "Copy failed";
            }
          }

          window.setTimeout(() => {
            button.removeAttribute("data-copied");
            if (status) {
              status.textContent = "";
            }
          }, 1800);
        });
      }
    </script>
  </body>
</html>
