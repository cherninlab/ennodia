{
  "name": "ennodia",
  "version": "0.0.0",
  "private": true,
  "description": "Make local and online AI tools work together.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ennodia": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "test": "bun test",
    "discover": "bun run src/dev/discover.ts",
    "smoke": "bun run src/dev/smoke.ts",
    "mcp:smoke": "bun run src/dev/mcp-smoke.ts",
    "task:smoke": "bun run src/dev/task-smoke.ts",
    "verify": "bun run check && bun run lint && bun run test && bun run task:smoke && bun run mcp:smoke"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  }
}
