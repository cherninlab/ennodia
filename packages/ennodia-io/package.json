{
  "name": "@cherninlab/ennodia-io",
  "version": "0.1.1",
  "description": "Experimental OpenAI-compatible local HTTP surface for Ennodia",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cherninlab/ennodia.git",
    "directory": "packages/ennodia-io"
  },
  "homepage": "https://ennodia.cherninlab.com/docs/reference/ennodia-io/",
  "bugs": {
    "url": "https://github.com/cherninlab/ennodia/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "api",
    "byok",
    "local",
    "openai-compatible"
  ],
  "files": [
    "bin/ennodia-io",
    "src/cli.ts",
    "src/index.ts",
    "src/internal.ts",
    "src/io.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "ennodia-io": "bin/ennodia-io"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run src/cli.ts",
    "check": "tsc --noEmit --project tsconfig.json",
    "test": "bun test src",
    "smoke": "bun run src/dev/io-smoke.ts",
    "pack:check": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --tag next"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "ennodia": "0.1.1"
  },
  "peerDependenciesMeta": {
    "ennodia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
